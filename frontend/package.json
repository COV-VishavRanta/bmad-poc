{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "dev:fast": "next dev --turbopack --port 3000 --experimental-https",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev --turbopack --port 3000",
    "dev:profile": "next dev --turbopack --port 3000 --experimental-debug",
    "build": "next build --turbopack",
    "build:analyze": "ANALYZE=true next build --turbopack",
    "start": "next start",
    "start:prod": "NODE_ENV=production next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:staged": "lint-staged",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "clean": "rm -rf .next out dist",
    "clean:deps": "rm -rf node_modules package-lock.json && npm install",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "health": "curl -f http://localhost:3000 || exit 1",
    "health:backend": "curl -f http://localhost:8000/api/health || exit 1",
    "health:full": "node -e \"require('child_process').exec('../dev-health.sh --detailed', (e,o) => console.log(o))\"",
    "health:monitor": "node -e \"require('child_process').spawn('../dev-health.sh', ['--continuous'], {stdio:'inherit'})\"",
    "check-all": "npm run type-check && npm run lint && npm run format:check",
    "fix-all": "npm run format && npm run lint:fix",
    "db:status": "node -e \"require('child_process').exec('../db-manage.sh status', (e,o,er) => console.log(o||er))\"",
    "db:migrate": "node -e \"require('child_process').exec('../db-manage.sh upgrade', (e,o,er) => console.log(o||er))\"",
    "db:seed": "node -e \"require('child_process').exec('../db-manage.sh seed', (e,o,er) => console.log(o||er))\"",
    "db:reset": "node -e \"require('child_process').exec('../db-manage.sh reset', (e,o,er) => console.log(o||er))\"",
    "test:all": "node -e \"require('child_process').spawn('../test-automation.sh', ['all'], {stdio:'inherit'})\"",
    "test:ci": "node -e \"require('child_process').spawn('../test-automation.sh', ['ci'], {stdio:'inherit'})\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.1",
    "@mui/icons-material": "^7.3.1",
    "@mui/material": "^7.3.1",
    "@mui/system": "^7.3.1",
    "@mui/x-date-pickers": "^8.10.2",
    "@types/js-cookie": "^3.0.6",
    "js-cookie": "^3.0.5",
    "next": "15.5.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.62.0",
    "zod": "^4.0.17",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "typescript": "5.9.2"
  }
}
